{
  "name": "qwiki",
  "displayName": "Qwiki",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onView:qwiki.wikiView",
    "onCommand:qwiki.createQuickWiki",
    "onCommand:qwiki.show",
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "Qwiki",
      "properties": {
        "qwiki.provider.google-ai-studio": {
          "type": "object",
          "default": {},
          "description": "Google AI Studio provider configuration.",
          "properties": {
            "name": {
              "type": "string",
              "default": "Google AI Studio",
              "description": "Provider display name"
            },
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Whether the provider is enabled"
            },
            "apiKey": {
              "type": "string",
              "default": "",
              "description": "Google AI Studio API key"
            },
            "model": {
              "type": "string",
              "default": "gemini-1.5-flash",
              "description": "Default model to use"
            },
            "temperature": {
              "type": "number",
              "default": 0.7,
              "minimum": 0,
              "maximum": 2,
              "description": "Temperature for generation"
            },
            "maxTokens": {
              "type": "number",
              "default": 2048,
              "minimum": 1,
              "maximum": 32000,
              "description": "Maximum tokens to generate"
            }
          }
        },
        "qwiki.provider.zai": {
          "type": "object",
          "default": {},
          "description": "Z.ai provider configuration.",
          "properties": {
            "name": {
              "type": "string",
              "default": "Z.ai",
              "description": "Provider display name"
            },
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Whether the provider is enabled"
            },
            "apiKey": {
              "type": "string",
              "default": "",
              "description": "Z.ai API key"
            },
            "model": {
              "type": "string",
              "default": "gpt-4o",
              "description": "Default model to use"
            },
            "temperature": {
              "type": "number",
              "default": 0.7,
              "minimum": 0,
              "maximum": 2,
              "description": "Temperature for generation"
            },
            "maxTokens": {
              "type": "number",
              "default": 2048,
              "minimum": 1,
              "maximum": 32000,
              "description": "Maximum tokens to generate"
            }
          }
        },
        "qwiki.provider.openrouter": {
          "type": "object",
          "default": {},
          "description": "OpenRouter provider configuration.",
          "properties": {
            "name": {
              "type": "string",
              "default": "OpenRouter",
              "description": "Provider display name"
            },
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Whether the provider is enabled"
            },
            "apiKey": {
              "type": "string",
              "default": "",
              "description": "OpenRouter API key"
            },
            "model": {
              "type": "string",
              "default": "anthropic/claude-3.5-sonnet",
              "description": "Default model to use"
            },
            "temperature": {
              "type": "number",
              "default": 0.7,
              "minimum": 0,
              "maximum": 2,
              "description": "Temperature for generation"
            },
            "maxTokens": {
              "type": "number",
              "default": 2048,
              "minimum": 1,
              "maximum": 32000,
              "description": "Maximum tokens to generate"
            }
          }
        },
        "qwiki.provider.cohere": {
          "type": "object",
          "default": {},
          "description": "Cohere provider configuration.",
          "properties": {
            "name": {
              "type": "string",
              "default": "Cohere",
              "description": "Provider display name"
            },
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Whether the provider is enabled"
            },
            "apiKey": {
              "type": "string",
              "default": "",
              "description": "Cohere API key"
            },
            "model": {
              "type": "string",
              "default": "command-r-plus",
              "description": "Default model to use"
            },
            "temperature": {
              "type": "number",
              "default": 0.7,
              "minimum": 0,
              "maximum": 2,
              "description": "Temperature for generation"
            },
            "maxTokens": {
              "type": "number",
              "default": 2048,
              "minimum": 1,
              "maximum": 32000,
              "description": "Maximum tokens to generate"
            }
          }
        },
        "qwiki.provider.huggingface": {
          "type": "object",
          "default": {},
          "description": "HuggingFace provider configuration.",
          "properties": {
            "name": {
              "type": "string",
              "default": "HuggingFace",
              "description": "Provider display name"
            },
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Whether the provider is enabled"
            },
            "apiKey": {
              "type": "string",
              "default": "",
              "description": "HuggingFace API key"
            },
            "model": {
              "type": "string",
              "default": "mistralai/Mixtral-8x7B-Instruct-v0.1",
              "description": "Default model to use"
            },
            "temperature": {
              "type": "number",
              "default": 0.7,
              "minimum": 0,
              "maximum": 2,
              "description": "Temperature for generation"
            },
            "maxTokens": {
              "type": "number",
              "default": 2048,
              "minimum": 1,
              "maximum": 32000,
              "description": "Maximum tokens to generate"
            }
          }
        },
        "qwiki.zaiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Z.ai API base URL (OpenAI-compatible). Leave blank for default."
        },
        "qwiki.googleAIEndpoint": {
          "type": "string",
          "enum": [
            "openai-compatible",
            "native"
          ],
          "default": "openai-compatible",
          "description": "Google AI Studio endpoint type. Use 'openai-compatible' for OpenAI-compatible endpoint or 'native' for Google's native endpoint."
        },
        "qwiki.defaultProviderId": {
          "type": "string",
          "default": "",
          "description": "Default LLM provider to use for wiki generation (e.g., 'google-ai-studio', 'openrouter', 'zai').",
          "enum": [
            "",
            "google-ai-studio",
            "zai",
            "openrouter",
            "cohere",
            "huggingface"
          ]
        },
        "qwiki.autoGenerateWiki": {
          "type": "boolean",
          "default": false,
          "description": "Automatically generate wiki when a file is opened or saved."
        },
        "qwiki.wikiOutputFormat": {
          "type": "string",
          "default": "markdown",
          "description": "Default output format for generated wikis.",
          "enum": [
            "markdown",
            "html",
            "pdf"
          ]
        },
        "qwiki.maxContextLength": {
          "type": "integer",
          "default": 8000,
          "minimum": 1000,
          "maximum": 128000,
          "description": "Maximum context length (in tokens) to send to the LLM."
        },
        "qwiki.enableCaching": {
          "type": "boolean",
          "default": true,
          "description": "Enable caching for generated wikis and project context."
        },
        "qwiki.cacheExpirationHours": {
          "type": "integer",
          "default": 24,
          "minimum": 1,
          "maximum": 168,
          "description": "Number of hours before cached entries expire (1-168 hours)."
        },
        "qwiki.enablePerformanceMonitoring": {
          "type": "boolean",
          "default": true,
          "description": "Enable performance monitoring and metrics collection."
        },
        "qwiki.enableErrorReporting": {
          "type": "boolean",
          "default": true,
          "description": "Enable error reporting and analytics."
        },
        "qwiki.logLevel": {
          "type": "string",
          "default": "info",
          "description": "Logging level for the extension.",
          "enum": [
            "error",
            "warn",
            "info",
            "debug"
          ]
        },
        "qwiki.uiTheme": {
          "type": "string",
          "default": "auto",
          "description": "UI theme for the Qwiki webview panel.",
          "enum": [
            "light",
            "dark",
            "auto"
          ]
        },
        "qwiki.language": {
          "type": "string",
          "default": "en",
          "description": "Language for generated documentation.",
          "enum": [
            "en",
            "es",
            "fr",
            "de",
            "zh",
            "ja",
            "ko"
          ]
        },
        "qwiki.autoSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically save generated wikis to the .qwiki folder."
        },
        "qwiki.backupEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic backups of configuration and wikis."
        },
        "qwiki.backupRetentionDays": {
          "type": "integer",
          "default": 7,
          "minimum": 1,
          "maximum": 90,
          "description": "Number of days to retain backups (1-90 days)."
        },
        "qwiki.global": {
          "type": "object",
          "default": {},
          "description": "Global Qwiki configuration settings (internal use)."
        },
        "qwiki.enableSemanticCaching": {
          "type": "boolean",
          "default": false,
          "description": "Enable semantic caching for wiki generation, file relevance analysis, and context suggestions. Uses embeddings to find similar cached results."
        },
        "qwiki.semanticSimilarityThreshold": {
          "type": "number",
          "default": 0.8,
          "minimum": 0,
          "maximum": 1,
          "description": "Similarity threshold for semantic cache matching (0.0-1.0). Higher values require closer matches."
        },
        "qwiki.semanticCacheMaxEntries": {
          "type": "integer",
          "default": 100,
          "minimum": 10,
          "maximum": 1000,
          "description": "Maximum number of entries in the semantic cache. Older entries are evicted when the limit is reached."
        },
        "qwiki.migration.version": {
          "type": "string",
          "default": "1.0.0",
          "description": "Current migration version for configuration migration."
        },
        "qwiki.migration.globalBackup": {
          "type": "object",
          "default": {},
          "description": "Global backup storage for configuration migrations."
        }
      }
    },
    "commands": [
      {
        "command": "qwiki.show",
        "title": "Qwiki: Show"
      },
      {
        "command": "qwiki.viewSettings",
        "title": "Qwiki: Settings"
      },
      {
        "command": "qwiki.viewSavedWikis",
        "title": "Qwiki: Saved Wikis"
      },
      {
        "command": "qwiki.viewErrorHistory",
        "title": "Qwiki: Error History"
      },
      {
        "command": "qwiki.createQuickWiki",
        "title": "Qwiki: Generate a Quick Wiki!"
      },
      {
        "command": "qwiki.selectProvider",
        "title": "Qwiki: Select Provider"
      },
      {
        "command": "qwiki.cancelActiveRequest",
        "title": "Qwiki: Cancel Active Request"
      },
      {
        "command": "qwiki.toggleOutputChannel",
        "title": "Qwiki: Toggle Output Channel"
      },
      {
        "command": "qwiki.toggleLoggingMode",
        "title": "Qwiki: Toggle Logging Mode"
      },
      {
        "command": "qwiki.toggleSemanticCaching",
        "title": "Qwiki: Toggle Semantic Caching"
      },
      {
        "command": "qwiki.viewCacheStatistics",
        "title": "Qwiki: View Cache Statistics"
      },
      {
        "command": "qwiki.viewMetricsDashboard",
        "title": "Qwiki: View Metrics Dashboard"
      },
      {
        "command": "qwiki.semanticSearch",
        "title": "Qwiki: Semantic Search"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "qwiki.cancelActiveRequest",
          "when": "qwiki.hasActiveGeneration"
        }
      ],
      "editor/context": [
        {
          "command": "qwiki.createQuickWiki",
          "when": "editorTextFocus",
          "group": "navigation@9"
        }
      ],
      "view/title": []
    },
    "keybindings": [
      {
        "command": "qwiki.createQuickWiki",
        "key": "ctrl+shift+q",
        "mac": "cmd+shift+q",
        "when": "editorTextFocus"
      }
    ],
    "views": {
      "qwiki": [
        {
          "id": "qwiki.wikiView",
          "name": "Qwiki",
          "type": "webview"
        },
        {
          "id": "qwiki.savedWikis",
          "name": "Saved Wikis",
          "when": "qwiki.hasSavedWikis"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "qwiki",
          "title": "Qwiki",
          "icon": "resources/qwiki-icon.svg"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "qwiki.wikiEditor",
        "displayName": "Qwiki Editor",
        "selector": [
          {
            "filenamePattern": "**/*.qwiki.md"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "install:all": "pnpm install && cd webview-ui && pnpm install",
    "start:webview": "cd webview-ui && pnpm run start",
    "build:webview": "cd webview-ui && pnpm run build",
    "dev:webview": "cd webview-ui && pnpm run dev",
    "compile:normal": "pnpm run compile",
    "compile:verbose": "cross-env LOG_MODE=verbose webpack --mode development",
    "vscode:prepublish": "pnpm run package",
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "watch:verbose": "cross-env LOG_MODE=verbose webpack --mode development --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run lint",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:webview": "cd webview-ui && pnpm run lint",
    "format": "prettier --cache --write .",
    "format:check": "prettier --cache --check .",
    "fix-imports": "tsc scripts/fix-imports.ts --outDir scripts --module commonjs --esModuleInterop --skipLibCheck --resolveJsonModule && node scripts/fix-imports.js"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.105.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.102.0",
    "webpack-cli": "^6.0.1",
    "cross-env": "^7.0.3"
  }
}
