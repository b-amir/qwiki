{
  "name": "qwiki",
  "displayName": "Qwiki",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Qwiki",
      "properties": {
        "qwiki.provider.google-ai-studio": {
          "type": "object",
          "default": {},
          "description": "Google AI Studio provider configuration.",
          "properties": {
            "name": {
              "type": "string",
              "default": "Google AI Studio",
              "description": "Provider display name"
            },
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Whether the provider is enabled"
            },
            "apiKey": {
              "type": "string",
              "default": "",
              "description": "Google AI Studio API key"
            },
            "model": {
              "type": "string",
              "default": "gemini-1.5-flash",
              "description": "Default model to use"
            },
            "temperature": {
              "type": "number",
              "default": 0.7,
              "minimum": 0,
              "maximum": 2,
              "description": "Temperature for generation"
            },
            "maxTokens": {
              "type": "number",
              "default": 2048,
              "minimum": 1,
              "maximum": 32000,
              "description": "Maximum tokens to generate"
            }
          }
        },
        "qwiki.provider.zai": {
          "type": "object",
          "default": {},
          "description": "Z.ai provider configuration.",
          "properties": {
            "name": {
              "type": "string",
              "default": "Z.ai",
              "description": "Provider display name"
            },
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Whether the provider is enabled"
            },
            "apiKey": {
              "type": "string",
              "default": "",
              "description": "Z.ai API key"
            },
            "model": {
              "type": "string",
              "default": "gpt-4o",
              "description": "Default model to use"
            },
            "temperature": {
              "type": "number",
              "default": 0.7,
              "minimum": 0,
              "maximum": 2,
              "description": "Temperature for generation"
            },
            "maxTokens": {
              "type": "number",
              "default": 2048,
              "minimum": 1,
              "maximum": 32000,
              "description": "Maximum tokens to generate"
            }
          }
        },
        "qwiki.provider.openrouter": {
          "type": "object",
          "default": {},
          "description": "OpenRouter provider configuration.",
          "properties": {
            "name": {
              "type": "string",
              "default": "OpenRouter",
              "description": "Provider display name"
            },
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Whether the provider is enabled"
            },
            "apiKey": {
              "type": "string",
              "default": "",
              "description": "OpenRouter API key"
            },
            "model": {
              "type": "string",
              "default": "anthropic/claude-3.5-sonnet",
              "description": "Default model to use"
            },
            "temperature": {
              "type": "number",
              "default": 0.7,
              "minimum": 0,
              "maximum": 2,
              "description": "Temperature for generation"
            },
            "maxTokens": {
              "type": "number",
              "default": 2048,
              "minimum": 1,
              "maximum": 32000,
              "description": "Maximum tokens to generate"
            }
          }
        },
        "qwiki.provider.cohere": {
          "type": "object",
          "default": {},
          "description": "Cohere provider configuration.",
          "properties": {
            "name": {
              "type": "string",
              "default": "Cohere",
              "description": "Provider display name"
            },
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Whether the provider is enabled"
            },
            "apiKey": {
              "type": "string",
              "default": "",
              "description": "Cohere API key"
            },
            "model": {
              "type": "string",
              "default": "command-r-plus",
              "description": "Default model to use"
            },
            "temperature": {
              "type": "number",
              "default": 0.7,
              "minimum": 0,
              "maximum": 2,
              "description": "Temperature for generation"
            },
            "maxTokens": {
              "type": "number",
              "default": 2048,
              "minimum": 1,
              "maximum": 32000,
              "description": "Maximum tokens to generate"
            }
          }
        },
        "qwiki.provider.huggingface": {
          "type": "object",
          "default": {},
          "description": "HuggingFace provider configuration.",
          "properties": {
            "name": {
              "type": "string",
              "default": "HuggingFace",
              "description": "Provider display name"
            },
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Whether the provider is enabled"
            },
            "apiKey": {
              "type": "string",
              "default": "",
              "description": "HuggingFace API key"
            },
            "model": {
              "type": "string",
              "default": "mistralai/Mixtral-8x7B-Instruct-v0.1",
              "description": "Default model to use"
            },
            "temperature": {
              "type": "number",
              "default": 0.7,
              "minimum": 0,
              "maximum": 2,
              "description": "Temperature for generation"
            },
            "maxTokens": {
              "type": "number",
              "default": 2048,
              "minimum": 1,
              "maximum": 32000,
              "description": "Maximum tokens to generate"
            }
          }
        },
        "qwiki.zaiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Z.ai API base URL (OpenAI-compatible). Leave blank for default."
        },
        "qwiki.googleAIEndpoint": {
          "type": "string",
          "enum": [
            "openai-compatible",
            "native"
          ],
          "default": "openai-compatible",
          "description": "Google AI Studio endpoint type. Use 'openai-compatible' for OpenAI-compatible endpoint or 'native' for Google's native endpoint."
        },
        "qwiki.global": {
          "type": "object",
          "default": {},
          "description": "Global Qwiki configuration settings."
        },
        "qwiki.migration.version": {
          "type": "string",
          "default": "1.0.0",
          "description": "Current migration version for configuration migration."
        },
        "qwiki.migration.globalBackup": {
          "type": "object",
          "default": {},
          "description": "Global backup storage for configuration migrations."
        }
      }
    },
    "commands": [
      {
        "command": "qwiki.show",
        "title": "Qwiki: Show"
      },
      {
        "command": "qwiki.viewSettings",
        "title": "Qwiki: Settings"
      },
      {
        "command": "qwiki.viewSavedWikis",
        "title": "Qwiki: Saved Wikis"
      },
      {
        "command": "qwiki.viewErrorHistory",
        "title": "Qwiki: Error History"
      },
      {
        "command": "qwiki.createQuickWiki",
        "title": "Qwiki: Create a quick wiki!"
      },
      {
        "command": "qwiki.createWikiAggregation",
        "title": "Qwiki: Create Wiki Aggregation"
      },
      {
        "command": "qwiki.updateReadme",
        "title": "Qwiki: Update README"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "qwiki.createQuickWiki",
          "when": "editorTextFocus",
          "group": "navigation@9"
        }
      ],
      "view/title": [
        {
          "command": "qwiki.createWikiAggregation",
          "when": "view == qwiki.wikiView",
          "group": "navigation@1"
        },
        {
          "command": "qwiki.updateReadme",
          "when": "view == qwiki.wikiView",
          "group": "navigation@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "qwiki.createQuickWiki",
        "key": "ctrl+shift+q",
        "mac": "cmd+shift+q",
        "when": "editorTextFocus"
      }
    ],
    "views": {
      "qwiki": [
        {
          "id": "qwiki.wikiView",
          "name": "Qwiki",
          "type": "webview"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "qwiki",
          "title": "Qwiki",
          "icon": "resources/qwiki-icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "install:all": "pnpm install && cd webview-ui && pnpm install",
    "start:webview": "cd webview-ui && pnpm run start",
    "build:webview": "cd webview-ui && pnpm run build",
    "dev:webview": "cd webview-ui && pnpm run dev",
    "vscode:prepublish": "pnpm run package",
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run lint",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:webview": "cd webview-ui && pnpm run lint",
    "format": "prettier --cache --write .",
    "format:check": "prettier --cache --check ."
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.105.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.102.0",
    "webpack-cli": "^6.0.1"
  }
}
