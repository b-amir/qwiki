{
  "name": "qwiki",
  "displayName": "Qwiki",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Qwiki",
      "properties": {
        "qwiki.zaiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Z.ai API base URL (OpenAI-compatible). Leave blank for default."
        }
      }
    },
    "commands": [
      {
        "command": "qwiki.show",
        "title": "Qwiki: Show"
      },
      {
        "command": "qwiki.viewSettings",
        "title": "Qwiki: Settings",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "qwiki.viewSettings",
          "when": "view == qwiki.wikiView",
          "group": "navigation@1"
        }
      ]
    },
    "views": {
      "qwiki": [
        {
          "id": "qwiki.wikiView",
          "name": "Qwiki",
          "type": "webview"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "qwiki",
          "title": "Qwiki",
          "icon": "resources/qwiki-icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "install:all": "pnpm install && cd webview-ui && pnpm install",
    "start:webview": "cd webview-ui && pnpm run start",
    "build:webview": "cd webview-ui && pnpm run build",
    "dev:webview": "cd webview-ui && pnpm run dev",
    "vscode:prepublish": "pnpm run package",
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run lint",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:webview": "cd webview-ui && pnpm run lint",
    "format": "prettier --cache --write .",
    "format:check": "prettier --cache --check ."
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.105.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.102.0",
    "webpack-cli": "^6.0.1"
  }
}
